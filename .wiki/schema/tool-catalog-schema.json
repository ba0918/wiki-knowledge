{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tool Catalog",
  "description": "wiki-tool-query の実行契約の真実源。接続先・制約・credential_ref を git 管理 JSON で宣言する。実行時検証は skills/wiki/scripts/lib/service/tool_catalog.py の hand-rolled validator が担い、本 schema との全制約同期は test_tool_catalog.py が機械検証する。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tools"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/definitions/tool" }
    }
  },
  "definitions": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_id",
        "type",
        "connection",
        "allowed_tables",
        "limits",
        "allowed_statements",
        "delivery"
      ],
      "properties": {
        "tool_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{0,126}[a-z0-9]$|^[a-z0-9]$"
        },
        "type": {
          "enum": ["sqlite"]
        },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "description": "DB ファイルパス。base_dir（省略時は wiki_root）配下に封じ込め、symlink は全 segment で拒否される"
            },
            "base_dir": {
              "type": "string",
              "minLength": 1,
              "description": "path の封じ込め先。絶対パス、または wiki_root 相対"
            }
          }
        },
        "credential_ref": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{0,126}[a-z0-9]$|^[a-z0-9]$",
          "description": "{wiki_root}/.local/credentials.json 内のキー。sqlite はファイル接続のため省略可（postgres 追加時に必須化）"
        },
        "allowed_tables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,127}$"
          },
          "description": "relation allowlist。view を含める場合はその基底 relation も必須（authorizer は基底 table の READ を発火する）"
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_rows", "max_result_bytes", "max_cell_bytes", "timeout_sec"],
          "properties": {
            "max_rows": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000000
            },
            "max_result_bytes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 268435456,
              "description": "無害化後 CSV encoded bytes の累積上限"
            },
            "max_cell_bytes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1048576,
              "description": "計測規則: TEXT = UTF-8 encoded bytes / BLOB = raw bytes / 数値 = 文字列化後 bytes"
            },
            "timeout_sec": {
              "type": "integer",
              "minimum": 1,
              "maximum": 600
            }
          }
        },
        "allowed_statements": {
          "const": ["select"]
        },
        "delivery": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed_dirs"],
          "properties": {
            "allowed_dirs": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "publish 先として許可する directory。絶対パス、または wiki_root 相対"
            }
          }
        }
      }
    }
  }
}
