{
  "schema_version": 1,
  "tools": [
    {
      "tool_id": "sample-events-db",
      "type": "sqlite",
      "connection": {
        "path": "data/sample-events.sqlite3"
      },
      "allowed_tables": ["users", "registrations", "refunds"],
      "limits": {
        "max_rows": 10000,
        "max_result_bytes": 10485760,
        "max_cell_bytes": 65536,
        "timeout_sec": 60
      },
      "allowed_statements": ["select"],
      "delivery": {
        "allowed_dirs": ["outputs/deliveries"]
      }
    },
    {
      "tool_id": "sample-analytics-pg",
      "type": "postgres",
      "connection": {
        "host": "analytics.db.internal",
        "port": 5432,
        "dbname": "analytics",
        "user": "wiki_readonly",
        "default_schema": "public",
        "canary_relation": "public.doctor_canary"
      },
      "credential_ref": "sample-analytics-pg",
      "allowed_tables": ["public.users", "public.registrations", "analytics.events"],
      "limits": {
        "max_rows": 10000,
        "max_result_bytes": 10485760,
        "max_cell_bytes": 65536,
        "timeout_sec": 60
      },
      "allowed_statements": ["select"],
      "delivery": {
        "allowed_dirs": ["outputs/deliveries"]
      }
    },
    {
      "tool_id": "sample-billing-mysql",
      "type": "mysql",
      "connection": {
        "host": "billing.db.internal",
        "port": 3306,
        "dbname": "billing",
        "user": "wiki_readonly"
      },
      "credential_ref": "sample-billing-mysql",
      "allowed_tables": ["users", "invoices"],
      "limits": {
        "max_rows": 10000,
        "max_result_bytes": 10485760,
        "max_cell_bytes": 65536,
        "timeout_sec": 60
      },
      "allowed_statements": ["select"],
      "delivery": {
        "allowed_dirs": ["outputs/deliveries"]
      }
    },
    {
      "tool_id": "sample-redash",
      "type": "http",
      "connection": {
        "base_url": "https://redash.internal",
        "allowed_endpoints": [
          { "method": "POST", "path_prefix": "/api/queries" },
          { "method": "GET", "path_prefix": "/api/query_results" }
        ],
        "auth_header_name": "Authorization",
        "auth_header_template": "Key {credential}"
      },
      "credential_ref": "sample-redash",
      "limits": {
        "max_rows": 10000,
        "max_result_bytes": 10485760,
        "max_cell_bytes": 65536,
        "timeout_sec": 60,
        "max_response_bytes": 8388608
      },
      "delivery": {
        "allowed_dirs": ["outputs/deliveries"]
      }
    }
  ]
}
